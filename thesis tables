# TABLE 4 — Stationarity Tests: ADF and KPSS Results
# =============================================================================
# Exact values from Section 3.1 / Table 4 of the thesis.
# Colour coding:
#   • Order column: gold  = I(1),  green = I(0)
#   • ADF p (level): red background when > 0.05  (cannot reject unit root)
#   • ADF p (Δ):     green background when < 0.05 (stationary in differences)
# =============================================================================

def table_4():
    print("Table 4 — Stationarity Tests")

    columns = [
        "Variable",
        "ADF Stat\n(level)",
        "ADF p\n(level)",
        "KPSS\nStat",
        "KPSS\np",
        "ADF Stat\n(Δ)",
        "ADF p\n(Δ)",
        "Order",
    ]
    col_widths = [1.6, 1.1, 1.0, 1.0, 0.9, 1.1, 1.0, 0.8]
    col_align  = ["l", "r", "r", "r", "r", "r", "r", "c"]

    # [Variable, ADF_stat_lev, ADF_p_lev, KPSS_stat, KPSS_p,
    #  ADF_stat_diff, ADF_p_diff, Order]
    data = [
        ["log(S&P500)", " 0.068",  "0.964",  "22.082", "< 0.01", "−19.890", "< 0.001", "I(1)"],
        ["CPI",         " 0.964",  "0.994",  "22.154", "< 0.01", "−50.967", "< 0.001", "I(1)"],
        ["FFR",         "−2.429",  "0.134",  " 0.950", "< 0.01", " −4.241", "0.0006",  "I(1)"],
        ["Unemployment","−12.718", "< 0.001"," 0.282", " 0.10",  " −1.727", "0.4173",  "I(0)"],
        ["log(M2)",     "−0.787",  "0.823",  "21.945", "< 0.01", "−19.468", "< 0.001", "I(1)"],
        ["log(GDP)",    "−0.679",  "0.852",  "21.497", "< 0.01", "−24.206", "< 0.001", "I(1)"],
        ["VIX",         "−2.205",  "0.204",  "11.963", "< 0.01", " −3.561", "0.0065",  "I(1)"],
    ]

    # Build per-cell colour grid
    row_colors = []
    for row in data:
        order      = row[7]
        adf_p_lev  = row[2]    # string
        adf_p_diff = row[6]    # string

        # ADF p-value level: red if > 0.05  (i.e. cannot reject H0 of unit root)
        if "< 0.001" in adf_p_lev:
            adf_lev_bg = GREEN_B
        elif "0." in adf_p_lev and float(adf_p_lev.replace(" ", "")) > 0.05:
            adf_lev_bg = RED_B
        else:
            adf_lev_bg = GREEN_B

        # ADF p diff: green if stationary (< 0.05)
        if "< 0.001" in adf_p_diff or (
                "0." in adf_p_diff and
                float(adf_p_diff.strip()) < 0.05):
            adf_diff_bg = GREEN_B
        else:
            adf_diff_bg = RED_B

        order_bg = GOLD_B if order == "I(1)" else GREEN_B

        row_colors.append([
            WHITE,        # Variable
            OFFWHITE,     # ADF stat level
            adf_lev_bg,   # ADF p level
            OFFWHITE,     # KPSS stat
            OFFWHITE,     # KPSS p
            OFFWHITE,     # ADF stat diff
            adf_diff_bg,  # ADF p diff
            order_bg,     # Order
        ])

    note = (
        "Note. ADF null hypothesis: unit root present (non-stationary). "
        "KPSS null hypothesis: series is stationary.  "
        "Critical value for ADF at 5%: −2.862.  "
        "KPSS critical value at 5%: 0.463.  "
        "Δ = first difference.  Lag length selected by AIC.  "
        "Colour coding — ADF p (level): red = cannot reject H₀ (I(1) confirmed); "
        "ADF p (Δ): green = stationary after differencing.  "
        "Order column: gold = I(1), green = I(0)."
    )

    draw_table(
        title      = "Table 4.  Stationarity Tests: ADF and KPSS Results",
        columns    = columns,
        rows       = data,
        col_widths = col_widths,
        col_align  = col_align,
        row_colors = row_colors,
        note       = note,
        filename   = "table_04_stationarity.png",
        figsize    = (13, 5.8),
    )


