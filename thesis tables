# DATA — same synthetic dataset and models as thesis_figures.py
# =============================================================================

np.random.seed(42)
N     = 16_957
DATES = pd.date_range("1959-12-01", periods=N, freq="B")
t     = np.arange(N)

gdp   = 543  * np.exp(0.00015 * t) + np.random.normal(0, 30, N).cumsum() * 0.1
m2    = 312  * np.exp(0.00016 * t) + np.random.normal(0, 20, N).cumsum() * 0.1
cpi   = 29.6 + t * 0.0134 + np.random.normal(0, 0.3, N).cumsum() * 0.05
ffr   = np.clip(6.81 + 4 * np.sin(2 * np.pi * t / 5000)
                + np.random.normal(0, 0.05, N).cumsum() * 0.1, 0.1, 15)
unemp = np.clip(6.06 + 1.5 * np.sin(2 * np.pi * t / 3000)
                + np.random.normal(0, 0.02, N).cumsum() * 0.05, 3, 13.08)
vix   = np.clip(20 + 3 * np.sin(2 * np.pi * t / 2000)
                + np.abs(np.random.normal(0, 1, N)).cumsum() * 0.01, 15, 54)
sp500 = np.clip(
    52 * np.exp(0.00025 * t)
    - 0.3  * ffr + 0.05 * m2 * 0.001 + 0.08 * gdp * 0.001
    - 0.5  * unemp - 0.2 * vix
    + np.random.normal(0, 0.5, N).cumsum() * 0.8,
    52, 14_000,
)

df = pd.DataFrame({
    "Date": DATES, "SP500": sp500, "CPI": cpi, "FFR": ffr,
    "Unemployment": unemp, "M2": m2, "GDP": gdp, "VIX": vix,
}).set_index("Date")
df["logSP500"] = np.log(df["SP500"])
df["logM2"]    = np.log(df["M2"])
df["logGDP"]   = np.log(df["GDP"])

FEATURES     = ["CPI", "FFR", "Unemployment", "logM2", "logGDP", "VIX"]
FEAT_LABELS  = ["CPI", "FFR", "Unemployment", "log(M2)", "log(GDP)", "VIX"]

df_diff  = df[["logSP500"] + FEATURES].diff().dropna()
X_raw    = df_diff[FEATURES].values
y        = df_diff["logSP500"].values
scaler   = StandardScaler()
X_scaled = scaler.fit_transform(X_raw)

n_total  = len(y)
n_train  = int(0.70 * n_total)
n_val    = int(0.15 * n_total)

X_train, y_train = X_scaled[:n_train],              y[:n_train]
X_val,   y_val   = X_scaled[n_train:n_train+n_val], y[n_train:n_train+n_val]
X_test,  y_test  = X_scaled[n_train+n_val:],        y[n_train+n_val:]

# ── fit models (exact hyperparameters from thesis) ──────────────
ols   = LinearRegression().fit(X_train, y_train)
ridge = RidgeCV(alphas=np.logspace(-3, 3, 50), cv=5).fit(X_train, y_train)
lasso = LassoCV(alphas=np.logspace(-5, 1, 50), cv=5,
                max_iter=5_000).fit(X_train, y_train)
rf    = RandomForestRegressor(n_estimators=200, max_depth=8,
                              min_samples_leaf=20, n_jobs=-1,
                              random_state=42).fit(X_train, y_train)
xgb   = XGBRegressor(n_estimators=300, max_depth=4, learning_rate=0.05,
                     subsample=0.8, colsample_bytree=0.8,
                     random_state=42, verbosity=0).fit(
    X_train, y_train, eval_set=[(X_val, y_val)], verbose=False)

# statsmodels OLS for inference
X_tr_sm    = sm.add_constant(X_train)
X_te_sm    = sm.add_constant(X_test, has_constant="add")
ols_sm     = sm.OLS(y_train, X_tr_sm).fit(cov_type="HC3")
residuals  = ols_sm.resid

print("Models ready.\n")


