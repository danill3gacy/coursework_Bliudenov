# =============================================================================
# SHARED HELPER — draw_table()
# =============================================================================
# Draws a publication-quality table as a matplotlib figure.
#
# Parameters
# ----------
# title      : str   — bold title shown above the table  (e.g. "Table 4. …")
# columns    : list  — column header strings
# rows       : list of lists — cell values (str or any __str__-able)
# col_widths : list  — relative widths of each column (will be normalised)
# row_colors : list of lists | None
#              Per-cell background colour. None → alternating white/offwhite.
# header_color : str  — header row background colour
# note       : str | None — footnote text shown below the table
# filename   : str   — output PNG path
# figsize    : tuple — (width, height) in inches; auto-expanded if needed
# col_align  : list  — 'l', 'c', or 'r' per column
# bold_cols  : list  — column indices whose content should be bold
# =============================================================================

def draw_table(
    title,
    columns,
    rows,
    col_widths=None,
    row_colors=None,
    header_color=NAVY,
    note=None,
    filename="table.png",
    figsize=None,
    col_align=None,
    bold_rows=None,       # row indices to render bold (0-based)
):
    n_cols = len(columns)
    n_rows = len(rows)

    # --- default column widths ---
    if col_widths is None:
        col_widths = [1.0] * n_cols
    total_w = sum(col_widths)
    col_widths = [w / total_w for w in col_widths]

    # --- column alignment ---
    if col_align is None:
        col_align = ["l"] * n_cols
    align_map = {"l": "left", "c": "center", "r": "right"}

    # --- figure height ---
    ROW_H   = 0.42          # inches per data row
    HEAD_H  = 0.55          # inches for header
    NOTE_H  = 0.55 if note else 0.1
    TITLE_H = 0.45
    auto_h  = TITLE_H + HEAD_H + n_rows * ROW_H + NOTE_H + 0.3
    fw      = figsize[0] if figsize else 11.0
    fh      = figsize[1] if figsize else max(auto_h, 2.5)

    fig = plt.figure(figsize=(fw, fh), facecolor="white")
    ax  = fig.add_axes([0, 0, 1, 1])
    ax.set_xlim(0, 1)
    ax.set_ylim(0, 1)
    ax.axis("off")

    # vertical layout (normalised 0→1 from top)
    title_y  = 1 - TITLE_H / fh
    header_y = title_y - HEAD_H / fh
    data_y0  = header_y - ROW_H / fh          # top of first data row
    note_y   = data_y0 - (n_rows - 1) * ROW_H / fh - ROW_H / fh - 0.02

    # column x boundaries (left edges)
    x_edges = [0.02]
    usable_w = 0.96
    for w in col_widths[:-1]:
        x_edges.append(x_edges[-1] + w * usable_w)
    x_edges.append(0.98)

    def cell_x(col_i, align):
        """Return (x, ha) for text placement inside a column."""
        left  = x_edges[col_i] + 0.008
        right = x_edges[col_i + 1] - 0.008
        mid   = (x_edges[col_i] + x_edges[col_i + 1]) / 2
        if align == "center":
            return mid, "center"
        elif align == "right":
            return right, "right"
        else:
            return left, "left"

    def draw_cell(x0, x1, y_top, height, fill_color, text, fontsize=9,
                  bold=False, color=TEXT, ha="left", va="center",
                  border=True):
        rect = FancyBboxPatch(
            (x0, y_top - height), x1 - x0, height,
            boxstyle="square,pad=0",
            linewidth=0.4 if border else 0,
            edgecolor=GREY_L,
            facecolor=fill_color,
        )
        ax.add_patch(rect)
        tx = x0 + 0.008 if ha == "left" else (
             x1 - 0.008 if ha == "right" else (x0 + x1) / 2)
        ax.text(tx, y_top - height / 2, str(text),
                ha=ha, va=va, fontsize=fontsize,
                fontweight="bold" if bold else "normal",
                color=color, wrap=True,
                multialignment=ha)

    # ── TITLE ────────────────────────────────────────────────────
    ax.text(0.5, title_y + (TITLE_H / fh) * 0.55, title,
            ha="center", va="center", fontsize=11,
            fontweight="bold", color=NAVY)

    # ── HEADER ROW ───────────────────────────────────────────────
    for ci, col in enumerate(columns):
        draw_cell(
            x_edges[ci], x_edges[ci + 1],
            title_y, HEAD_H / fh,
            fill_color=header_color,
            text=col, fontsize=9, bold=True,
            color=WHITE,
            ha=align_map[col_align[ci]],
        )

    # ── DATA ROWS ────────────────────────────────────────────────
    for ri, row in enumerate(rows):
        y_top_row = data_y0 - ri * ROW_H / fh

        # row background: alternating if no explicit colors given
        for ci, cell_val in enumerate(row):
            if row_colors is not None:
                bg = row_colors[ri][ci]
            else:
                bg = WHITE if ri % 2 == 0 else OFFWHITE

            is_bold = bold_rows is not None and ri in bold_rows
            draw_cell(
                x_edges[ci], x_edges[ci + 1],
                y_top_row, ROW_H / fh,
                fill_color=bg,
                text=cell_val,
                fontsize=8.8,
                bold=is_bold,
                ha=align_map[col_align[ci]],
            )

    # outer border
    outer = FancyBboxPatch(
        (0.02, note_y + 0.01 if note else data_y0 - n_rows * ROW_H / fh),
        0.96,
        title_y - (note_y + 0.01 if note else data_y0 - n_rows * ROW_H / fh),
        boxstyle="square,pad=0",
        linewidth=1.2, edgecolor=NAVY, facecolor="none"
    )
    ax.add_patch(outer)

    # ── NOTE ─────────────────────────────────────────────────────
    if note:
        ax.text(0.02, note_y, note, ha="left", va="top",
                fontsize=7.8, color=SUBTEXT,
                style="italic", wrap=True,
                multialignment="left")

    plt.savefig(filename, bbox_inches="tight", facecolor="white")
    plt.show()
    print(f"  Saved → {filename}")


