def table_8():
    print("Table 8 — Model Comparison")

    columns    = ["Model", "MAE", "RMSE", "MAPE (%)", "R²"]
    col_widths = [2.0, 1.5, 1.5, 1.5, 1.5]
    col_align  = ["l", "r", "r", "r", "r"]

    # compute from fitted models for exact reproducibility
    def metrics(model):
        pred = model.predict(X_test)
        mae  = np.mean(np.abs(y_test - pred))
        rmse = np.sqrt(np.mean((y_test - pred) ** 2))
        mape = np.mean(np.abs((y_test - pred) /
                              (np.abs(y_test) + 1e-8))) * 100
        r2   = r2_score(y_test, pred)
        return mae, rmse, mape, r2

    model_list = [
        ("OLS (Baseline)", ols),
        ("Ridge",          ridge),
        ("Lasso",          lasso),
        ("Random Forest",  rf),
        ("XGBoost",        xgb),
    ]

    rows_raw = []
    for name, m in model_list:
        mae, rmse, mape, r2 = metrics(m)
        rows_raw.append((name, mae, rmse, mape, r2))

    data = [
        [r[0], f"{r[1]:.5f}", f"{r[2]:.5f}", f"{r[3]:.2f}", f"{r[4]:.4f}"]
        for r in rows_raw
    ]

    # per-metric: best = green, worst = red, others = alternating
    mae_vals  = [r[1] for r in rows_raw]
    rmse_vals = [r[2] for r in rows_raw]
    r2_vals   = [r[4] for r in rows_raw]

    best_mae  = np.argmin(mae_vals);  worst_mae  = np.argmax(mae_vals)
    best_rmse = np.argmin(rmse_vals); worst_rmse = np.argmax(rmse_vals)
    best_r2   = np.argmax(r2_vals);   worst_r2   = np.argmin(r2_vals)

    row_colors = []
    for i in range(len(data)):
        bg   = WHITE if i % 2 == 0 else OFFWHITE
        mae_bg  = GREEN_B if i == best_mae  else (RED_B if i == worst_mae  else bg)
        rmse_bg = GREEN_B if i == best_rmse else (RED_B if i == worst_rmse else bg)
        r2_bg   = GREEN_B if i == best_r2   else (RED_B if i == worst_r2   else bg)
        row_colors.append([bg, mae_bg, rmse_bg, bg, r2_bg])

    note = (
        "Note. All models estimated on 70% training set (N = 11,869); "
        "evaluated on held-out 15% test set (N = 2,544). "
        "Negative R² indicates predictions are worse than the mean-prediction "
        "baseline, consistent with near-random-walk behaviour of daily equity returns. "
        "MAPE is distorted by near-zero observations in the denominator; "
        "MAE and RMSE are the primary comparison metrics. "
        "Colour coding: green = best value for that metric; red = worst."
    )

    draw_table(
        title      = "Table 8.  Model Performance Comparison on Held-Out Test Set (15% of sample)",
        columns    = columns,
        rows       = data,
        col_widths = col_widths,
        col_align  = col_align,
        row_colors = row_colors,
        note       = note,
        filename   = "table_08_model_comparison.png",
        figsize    = (11, 5.0),
    )


